# Supabase project credentials (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The following secrets must be set in Supabase Dashboard > Edge Functions > Secrets
# They are NOT used by the frontend directly — the edge function reads them at runtime.
#
# OPENROUTER_API_KEY=your-openrouter-api-key    (https://openrouter.ai/keys)
# YOU_API_KEY=your-you-com-api-key              (https://api.you.com)
